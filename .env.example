# Variáveis de ambiente para aplicação TODO List

# Modo de ambiente (development | production | test)
VITE_APP_ENV=development

# Configurações de notificação
VITE_NOTIFICATION_ENABLED=true
VITE_NOTIFICATION_TIMEOUT=5000

# Configurações de armazenamento
VITE_STORAGE_PREFIX=todo-list
VITE_MAX_TASKS=100
VITE_MAX_REMINDERS=100

# Configurações de logging
VITE_LOG_LEVEL=info
VITE_DEBUG=false

# Configurações de timeout para lembretes
VITE_REMINDER_CHECK_INTERVAL=5000
VITE_REMINDER_LEAD_TIME=300000

# API Configuration (se necessário)
# VITE_API_BASE_URL=http://localhost:3000/api
